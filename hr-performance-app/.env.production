# TSS PPM Frontend - Production Configuration

# Keycloak authentication
VITE_AUTH_ENABLED=true
VITE_KEYCLOAK_URL=/auth
VITE_KEYCLOAK_REALM=tss-ppm
VITE_KEYCLOAK_CLIENT_ID=tss-ppm-frontend

# Backend API URL (relative path, proxied by nginx)
VITE_API_URL=/api/v1

# Disable browser-based Whisper in production (use server)
VITE_BROWSER_WHISPER_DEFAULT=false
