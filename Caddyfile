# TSS PPM - Caddy Reverse Proxy Configuration
# For localhost, Caddy uses HTTP. For a real domain, it auto-enables HTTPS.

{$DOMAIN:localhost} {
    # ============================================
    # API BACKEND
    # ============================================
    handle /api/* {
        reverse_proxy api:3000
    }

    # ============================================
    # KEYCLOAK AUTHENTICATION
    # ============================================
    handle /auth/* {
        reverse_proxy keycloak:8080
    }

    # ============================================
    # WHISPER SPEECH-TO-TEXT
    # ============================================
    handle /whisper/* {
        uri strip_prefix /whisper
        reverse_proxy whisper:3001 {
            # Increased timeout for audio transcription
            transport http {
                read_timeout 120s
                write_timeout 120s
            }
        }
    }

    # ============================================
    # FRONTEND (React SPA)
    # ============================================
    handle /* {
        reverse_proxy frontend:80
    }

    # ============================================
    # COMPRESSION
    # ============================================
    encode gzip

    # ============================================
    # SECURITY HEADERS
    # ============================================
    header {
        # Prevent MIME type sniffing
        X-Content-Type-Options nosniff

        # Clickjacking protection (allow same origin for Keycloak iframes)
        X-Frame-Options SAMEORIGIN

        # Referrer policy
        Referrer-Policy strict-origin-when-cross-origin

        # XSS protection (legacy, but still useful)
        X-XSS-Protection "1; mode=block"

        # HSTS (only for non-localhost domains)
        # Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # Content Security Policy (adjust as needed)
        # Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' wss: https:; frame-ancestors 'self'"

        # Remove server header
        -Server
    }

    # ============================================
    # LOGGING
    # ============================================
    log {
        output stdout
        format console
        level INFO
    }
}
