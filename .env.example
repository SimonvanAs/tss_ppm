# TSS PPM Docker Environment Variables
# Copy this file to .env and update with your values

# Domain (use 'localhost' for development, your domain for production)
DOMAIN=localhost

# Database Password (change this!)
DB_PASSWORD=changeme_use_strong_password

# Keycloak Admin Credentials (change these!)
KC_ADMIN=admin
KC_ADMIN_PASSWORD=changeme_use_strong_password

# Whisper Configuration
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_WORKERS=2
