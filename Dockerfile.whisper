# Whisper server
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for audio processing
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY hr-performance-app/server/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy server code
COPY hr-performance-app/server/whisper_server.py ./

# Create uploads directory
RUN mkdir -p uploads

# Expose port
EXPOSE 3001

# Set environment variables
ENV FLASK_ENV=production
ENV PYTHONUNBUFFERED=1

# Pre-download the model during build (optional, makes first request faster)
RUN python -c "from transformers import AutoModelForSpeechSeq2Seq, AutoProcessor; \
    AutoModelForSpeechSeq2Seq.from_pretrained('openai/whisper-small'); \
    AutoProcessor.from_pretrained('openai/whisper-small')"

CMD ["python", "whisper_server.py"]
