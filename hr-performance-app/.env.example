# TSS PPM Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# Authentication (Keycloak)
# ===========================================

# Keycloak server URL (without trailing slash)
VITE_KEYCLOAK_URL=http://localhost:8080

# Keycloak realm name
VITE_KEYCLOAK_REALM=tss-ppm

# Keycloak client ID for the frontend SPA
VITE_KEYCLOAK_CLIENT_ID=tss-ppm-frontend

# Enable/disable authentication (set to 'false' for local development without Keycloak)
VITE_AUTH_ENABLED=true

# Allow anonymous access in development mode (only works when AUTH_ENABLED=false)
VITE_AUTH_ALLOW_ANONYMOUS=false

# ===========================================
# API Configuration
# ===========================================

# Backend API base URL
VITE_API_URL=http://localhost:3000/api/v1

# ===========================================
# Voice Input (Whisper)
# ===========================================

# Server-side Whisper API URL (optional, falls back to /api/transcribe)
VITE_WHISPER_API_URL=

# Enable browser-based Whisper by default (true/false)
VITE_BROWSER_WHISPER_DEFAULT=true

# ===========================================
# Feature Flags
# ===========================================

# Enable debug logging
VITE_DEBUG=false
